# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in your Supabase project → Settings → API

# Public URL — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Anon / public key — safe to expose in the browser (RLS protects the data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key — NEVER expose this on the client side
# Only used server-side for admin operations that bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
